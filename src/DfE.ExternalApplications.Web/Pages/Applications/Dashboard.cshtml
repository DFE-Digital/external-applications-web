@page "/applications/dashboard"
@using GovUK.Dfe.CoreLibs.Contracts.ExternalApplications.Enums
@using GovUK.Dfe.CoreLibs.Contracts.ExternalApplications.Models.Response
@using GovUk.Frontend.AspNetCore.TagHelpers
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel;
@addTagHelper *, GovUK.Dfe.CoreLibs.Security
@model DfE.ExternalApplications.Web.Pages.Applications.DashboardModel
@inject IAuthorizationService AuthService
@inject IConfiguration Configuration

@{
    ViewData["Title"] = Configuration["Layout:ServiceName"];
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full govuk-!-margin-bottom-6">
        
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-9">
            Your @AppTerminology.Plural
        </h1>

        @if (Model.HasError)
        {
            <div class="govuk-error-summary" aria-labelledby="error-summary-title" role="alert" data-module="govuk-error-summary">
                <h2 class="govuk-error-summary__title" id="error-summary-title">
                    There is a problem
                </h2>
                <div class="govuk-error-summary__body">
                    <span class="govuk-visually-hidden">Error: </span>
                    <p>@Model.ErrorMessage</p>
                </div>
            </div>
        }

        <h2 class="govuk-heading-l govuk-!-margin-bottom-3">
            @AppTerminology.PluralCapitalised in progress
        </h2>

        <form method="get" action="/applications/dashboard" class="govuk-!-margin-bottom-6">
            <div class="govuk-form-group">
                <label class="govuk-label" for="search-reference">
                    Search by reference number
                </label>
                <div class="govuk-input__wrapper">
                    <input class="govuk-input govuk-input--width-20" id="search-reference" name="searchReference"
                           type="search" value="@Model.SearchReference" autocomplete="off">
                    <button class="govuk-button govuk-!-margin-bottom-0" type="submit">Search</button>
                </div>
            </div>
            @if (Model.IsSearchActive)
            {
                <a class="govuk-link" href="/applications/dashboard">Clear search</a>
            }
        </form>

        @if (!Model.HasError && !Model.Applications.Any())
        {
            <p class="govuk-body">
                @if (Model.IsSearchActive)
                {
                    <span>No @AppTerminology.Plural found matching your search.</span>
                }
                else
                {
                    <span>You have no @AppTerminology.Plural in progress.</span>
                }
            </p>
        }
        else if (!Model.HasError)
        {
            <table class="govuk-table">
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header">Reference number</th>
                        <th scope="col" class="govuk-table__header">Date started</th>
                        <th scope="col" class="govuk-table__header">Date submitted</th>
                        <th scope="col" class="govuk-table__header">Status</th>
                        <th scope="col" class="govuk-table__header">Action</th>
                    </tr>
                </thead>
                <tbody class="govuk-table__body">
                    @foreach (var app in Model.Applications)
                    {
                        var action = app.CalculatedStatus == ApplicationStatus.Submitted ? $"View {AppTerminology.Singular}" : $"Continue {AppTerminology.Singular}";
                        var statusClass = app.CalculatedStatus == ApplicationStatus.Submitted ? "govuk-tag--green" :
                            app.CalculatedStatus == ApplicationStatus.InProgress ? "govuk-tag--blue" : "govuk-tag--grey";

                        var appStatusInfo = @app.CalculatedStatus.GetType().GetField(@app.CalculatedStatus.ToString());
                        var descriptionAttributes = (DescriptionAttribute[])appStatusInfo!.GetCustomAttributes(typeof(DescriptionAttribute), false);
                        var appStatusDescription = descriptionAttributes.Length > 0 ? descriptionAttributes[0].Description : @app.CalculatedStatus.ToString();

                        <tr class="govuk-table__row">
                            <td class="govuk-table__cell">@app.ApplicationReference</td>
                            <td class="govuk-table__cell">@app.DateCreated.ToString("d MMMM yyyy")</td>
                            <td class="govuk-table__cell">
                                @(app.DateSubmitted?.ToString("d MMMM yyyy") ?? "Not submitted")
                            </td>
                            <td class="govuk-table__cell">
                                <strong class="govuk-tag @statusClass">
                                    @appStatusDescription
                                </strong>
                            </td>
                            <td class="govuk-table__cell">
                                <a href="/applications/@app.ApplicationReference" class="govuk-link">
                                    @action
                                    <span class=govuk-visually-hidden>@app.ApplicationReference</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (Model.TotalPages > 1)
        {
            var searchParam = Model.IsSearchActive ? $"&searchReference={Uri.EscapeDataString(Model.SearchReference!)}" : "";
            <nav class="govuk-pagination" aria-label="Pagination">
                @if (Model.CurrentPage > 1)
                {
                    <div class="govuk-pagination__prev">
                        <a class="govuk-link govuk-pagination__link" href="?currentPage=@(Model.CurrentPage - 1)@searchParam" rel="prev">
                            <svg class="govuk-pagination__icon govuk-pagination__icon--prev" xmlns="http://www.w3.org/2000/svg" height="13" width="15" focusable="false" aria-hidden="true" viewBox="0 0 15 13">
                                <path d="m6.5938-0.0078125-6.7266 6.7266 6.7441 6.4062 1.377-1.449-4.1856-3.9768h12.896v-2h-12.984l4.2931-4.293-1.414-1.414z" />
                            </svg>
                            <span class="govuk-pagination__link-title">Previous<span class="govuk-visually-hidden"> page</span></span>
                        </a>
                    </div>
                }
                <ul class="govuk-pagination__list">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <li class="govuk-pagination__item govuk-pagination__item--current">
                                <a class="govuk-link govuk-pagination__link" href="?currentPage=@i@searchParam" aria-label="Page @i" aria-current="page">@i</a>
                            </li>
                        }
                        else if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.CurrentPage) <= 1)
                        {
                            <li class="govuk-pagination__item">
                                <a class="govuk-link govuk-pagination__link" href="?currentPage=@i@searchParam" aria-label="Page @i">@i</a>
                            </li>
                        }
                        else if (Math.Abs(i - Model.CurrentPage) == 2)
                        {
                            <li class="govuk-pagination__item govuk-pagination__item--ellipses">&ctdot;</li>
                        }
                    }
                </ul>
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <div class="govuk-pagination__next">
                        <a class="govuk-link govuk-pagination__link" href="?currentPage=@(Model.CurrentPage + 1)@searchParam" rel="next">
                            <span class="govuk-pagination__link-title">Next<span class="govuk-visually-hidden"> page</span></span>
                            <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" focusable="false" aria-hidden="true" viewBox="0 0 15 13">
                                <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7246z" />
                            </svg>
                        </a>
                    </div>
                }
            </nav>
        }

        <h2 class="govuk-heading-l govuk-!-margin-top-9">
            Start a new @AppTerminology.Singular
        </h2>
        <p class="govuk-body">If you start an @AppTerminology.Singular, you will be the lead applicant for it.</p>
        <form method="post">
            <button class="govuk-button govuk-!-margin-bottom-9" type="submit" asp-page-handler="CreateApplication" id="start-new-application-button">Start new @AppTerminology.Singular</button>
        </form>
    </div>
</div>
